              "criterion": "AC-001",
              "implementation_file": "src/feature.ts:45",
              "test_location": "tests/feature.test.ts:23"
            }
          ],
          "hard_gate_results": { "tests": 0, "types": 0, "lint": 0 },
          "verification_level": "L2",
          "verification_attempted": ["L1", "L2"]
        },
        "envelope_version": "1.0.0"
      }
    },

    "NEEDS_REWORK": {
