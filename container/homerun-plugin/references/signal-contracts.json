    "DIAGNOSIS_COMPLETE": {
      "producer": "homerun:diagnose",
      "envelope_example": {
        "signal": "DIAGNOSIS_COMPLETE",
        "timestamp": "2026-01-25T11:30:00Z",
        "source": { "skill": "homerun:diagnose" },
        "payload": {
          "root_cause": {
            "hypothesis": "Validation middleware strips password field before auth service",
            "evidence": [
              {
                "description": "validation.ts:23 deletes req.body.password",
                "source": "src/middleware/validation.ts:23",
                "supports": "Password field removed before hash"
              }
            ],
            "alternatives_considered": [
              {
                "hypothesis": "Client not sending password field",
                "rejected_because": "Request logging shows password in raw body"
              }
            ],
            "verified": true
          },
          "confidence": "high",
          "solutions": [
            {
              "title": "Remove password from stripped fields list",
              "type": "direct",
              "files": ["src/middleware/validation.ts"],
              "risk": "low"
            }
          ],
          "recommendation": {
            "solution_index": 0,
            "rationale": "Direct fix at root cause, minimal change"
          }
        },
        "envelope_version": "1.0.0"
      }
    },

    "DIAGNOSIS_INCONCLUSIVE": {
      "producer": "homerun:diagnose",
      "envelope_example": {
