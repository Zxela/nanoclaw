{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "2.0.0",
  "description": "Authoritative task type to model routing configuration (v4.0 — effort-proportional)",

  "task_routing": {
    "haiku": {
      "task_types": [
        "add_field",
        "add_method",
        "add_validation",
        "rename_refactor",
        "add_test",
        "add_config",
        "add_endpoint"
      ],
      "characteristics": "Mechanical, single-focus, <15 min",
      "max_parallel": 5,
      "decomposable": false,
      "default_methodology": "direct",
      "methodology_note": "Simple tasks use direct+tests, not full TDD cycle",
      "skip_step_0": true,
      "quality_gate": {
        "skip_structural_review": true,
        "skip_llm_autofix": true,
        "note": "Deterministic checks only (lint, types, tests). LLM phases have low signal-to-cost ratio for mechanical tasks."
      }
    },
    "sonnet": {
      "task_types": [
        "create_model",
        "create_service",
        "add_endpoint_complex",
        "create_middleware",
        "bug_fix",
        "integration_test"
      ],
      "characteristics": "Multi-file, requires judgment, 15-45 min",
      "max_parallel": 3,
      "decomposable": true,
      "default_methodology": "tdd",
      "methodology_note": "Complex tasks benefit from test-first design",
      "skip_step_0": false
    },
    "opus": {
      "task_types": [
        "architectural"
      ],
      "characteristics": "High-leverage decisions, decomposition cascades if wrong",
      "max_parallel": 1,
      "decomposable": false,
      "skip_step_0": false
    }
  },

  "phase_models": {
    "discovery": "inherit",
    "spec_review": "sonnet",
    "scope_analysis": "sonnet",
    "task_decomposition": "opus",
    "test_skeletons": "sonnet",
    "team_lead": "sonnet",
    "reviewer": "sonnet",
    "quality_check": "sonnet (haiku-tier sessions: LLM phases skipped, no model cost)",
    "diagnose": "sonnet",
    "reverse_engineer": "opus",
    "walkthrough": "sonnet"
  },

  "retry_strategy": {
    "order": ["fresh_agent", "same_agent", "escalate"],
    "note": "Fresh-context-first: first retry uses clean context with structured failure summary. Accumulated context from failed attempts degrades performance.",
    "fresh_agent_retries": 1,
    "same_agent_retries": 1,
    "escalation": {
      "from": "haiku",
      "to": "sonnet"
    }
  },

  "agent_limits": {
    "maxTurns": {
      "discovery": 30,
      "spec_review": 10,
      "scope_analysis": 12,
      "task_decomposition": 10,
      "implementer": 25,
      "reviewer": 15,
      "quality_check": 10,
      "team_lead": 50,
      "diagnose": 20,
      "reverse_engineer": 30,
      "test_skeletons": 15,
      "walkthrough": 15
    }
  },

  "scale_routing": {
    "small": {
      "max_implementers": 1,
      "skip_spec_review": true,
      "skip_scope_analysis": true,
      "skip_agent_teams": true,
      "skip_separate_reviewer": true,
      "preferred_model": "haiku"
    },
    "medium": {
      "max_implementers": 2,
      "skip_spec_review": false,
      "skip_scope_analysis": false,
      "skip_agent_teams": false,
      "skip_separate_reviewer": false,
      "preferred_model": "sonnet"
    },
    "large": {
      "max_implementers": 5,
      "skip_spec_review": false,
      "skip_scope_analysis": false,
      "skip_agent_teams": false,
      "skip_separate_reviewer": false,
      "preferred_model": null
    }
  },

  "test_requirements": {
    "haiku": {
      "add_field": "optional",
      "add_config": "optional",
      "rename_refactor": "optional",
      "add_method": "required",
      "add_validation": "required",
      "add_test": "required",
      "add_endpoint": "required"
    },
    "sonnet": "required",
    "opus": "required"
  },

  "no_test_exceptions": [
    "documentation_only",
    "config_static",
    "type_definitions_only",
    "dependency_update",
    "delete_dead_code",
    "rename_refactor",
    "add_field_when_consolidatable"
  ]
}
